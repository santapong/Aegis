# =============================================================================
# Aegis backend — environment template
#
# Copy to .env for local development (or set these in your platform's env UI:
# Render, Fly.io, Railway, AWS Secrets Manager, GCP Secret Manager, ...).
# Required vars are marked [REQUIRED]. The app refuses to start in production
# (DEBUG=false) with placeholder values.
# =============================================================================

# --- Database [REQUIRED] -----------------------------------------------------
# Aegis ships with SQLAlchemy + Alembic; any Postgres / MySQL / SQLite URL
# works. Recommended cloud Postgres: Neon, Supabase, Vercel Postgres, RDS,
# Cloud SQL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/money_management

# --- JWT [REQUIRED] ----------------------------------------------------------
# Must be ≥ 32 chars in production. Generate: `openssl rand -hex 32`
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- CORS [REQUIRED in production] -------------------------------------------
# JSON array of origins. Include every frontend URL the browser will use —
# Vercel preview deploys, custom domain, localhost for dev.
CORS_ORIGINS=["http://localhost:3000"]

# --- Public frontend URL [REQUIRED in production] ----------------------------
# Where the browser actually loads the UI from. Used to build Stripe
# success/cancel redirect URLs and any other server-issued links back to
# the UI. Set this to your real domain in production (e.g.
# https://app.example.com), or Stripe checkouts will 404 after payment.
FRONTEND_URL=http://localhost:3000

# --- Google OAuth (Optional — leave blank to disable /api/auth/google) ------
# Google ID-token flow (Google Identity Services). Frontend gets a one-time
# credential from Google's JS SDK and posts it to /api/auth/google; backend
# verifies it against this client ID. Get one from
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client IDs →
# Web application. Set the same value as NEXT_PUBLIC_GOOGLE_CLIENT_ID on the
# frontend. Authorized JavaScript origins must include your frontend URL.
GOOGLE_OAUTH_CLIENT_ID=

# --- AI (Optional — leave blank to disable /api/ai/* routes) ----------------
AI_PROVIDER=anthropic   # anthropic | typhoon | groq

# Anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Typhoon (OpenAI-compatible) — https://opentyphoon.ai
TYPHOON_API_KEY=
TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
TYPHOON_MODEL=typhoon-v2.1-12b-instruct

# Groq (OpenAI-compatible) — https://console.groq.com
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- Stripe (Optional — leave blank to disable /api/payments/*) -------------
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MODE=test

# --- App --------------------------------------------------------------------
DEBUG=false
# "json" for production (structured logs ingested by CloudWatch / Cloud
# Logging), "text" for dev (colorized).
LOG_FORMAT=json

# Per-IP rate limit applied to every authenticated endpoint.
RATE_LIMIT_PER_MINUTE=100
