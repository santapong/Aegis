# =============================================================================
# Aegis frontend — environment template
#
# Copy to .env.local for development, or set these in your hosting platform
# (Vercel project settings, ECS task definition, Cloud Run env, ...).
#
# Aegis prefers same-origin auth: the browser hits `/api/*` and Next.js
# rewrites server-side to BACKEND_INTERNAL_URL. So in production the only
# variable you typically set is BACKEND_INTERNAL_URL.
# =============================================================================

# --- Required in production -------------------------------------------------
# Backend's reachable URL from this Next.js server.
#   - Vercel:        public HTTPS URL of your backend host (https://api.example.com)
#   - docker-compose: service name + port (http://backend:8000)
#   - local native:  http://localhost:8000
BACKEND_INTERNAL_URL=http://localhost:8000

# --- Google sign-in (Optional — leave blank to hide the button) -------------
# Public client ID from Google Cloud Console. Must match the backend's
# GOOGLE_OAUTH_CLIENT_ID exactly. Authorized JavaScript origins in the GCP
# console must include every frontend URL the browser will load from
# (including Vercel preview deploys if you want them to work).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Optional ---------------------------------------------------------------
# Override only if you need the browser to hit the backend DIRECTLY (e.g. to
# bypass Vercel's response buffering for streaming AI replies). When empty,
# the browser uses relative `/api/*` URLs via the rewrite proxy — the
# recommended default since it avoids CORS and keeps auth same-origin.
# NEXT_PUBLIC_API_URL=
