# Database — supports PostgreSQL, MySQL, and SQLite
# PostgreSQL (Docker): postgresql://postgres:postgres@db:5432/money_management
# PostgreSQL (local):  postgresql://postgres:postgres@localhost:5432/money_management
# MySQL:               mysql+pymysql://root:password@localhost:3306/money_management
# SQLite:              sqlite:///./money_management.db
DATABASE_URL=sqlite:///./money_management.db

# JWT Authentication
# Generate a strong secret in production: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# AI (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxxxx
AI_MODEL=claude-sonnet-4-20250514

# App
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Stripe (Test Mode)
# Get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_MODE=test
