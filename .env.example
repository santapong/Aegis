# ============================================================
# Aegis configuration template.
# `make setup` generates a real .env from this file with a
# freshly generated JWT_SECRET_KEY and Docker-friendly defaults.
#
# Required: DATABASE_URL, JWT_SECRET_KEY
# Optional: ANTHROPIC_API_KEY (unlocks /api/ai/*), STRIPE_* (/api/payments/*)
# ============================================================

# --- Database -----------------------------------------------
# DOCKER (default for `make up` / `make dev`): uses the compose "db" service.
DATABASE_URL=postgresql://postgres:postgres@db:5432/money_management
# NATIVE alternatives — uncomment one of these instead if not using Docker:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/money_management
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/money_management
# DATABASE_URL=sqlite:///./money_management.db

# --- JWT (REQUIRED) -----------------------------------------
# In production (DEBUG=false) the app refuses to start with this placeholder
# or a secret shorter than 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- AI (OPTIONAL — leave blank to disable /api/ai/* routes) -
# Pick one provider; only that provider's key is consulted.
AI_PROVIDER=anthropic   # anthropic | typhoon | groq

# Anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Typhoon (OpenAI-compatible) — https://opentyphoon.ai
TYPHOON_API_KEY=
TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
TYPHOON_MODEL=typhoon-v2.1-12b-instruct

# Groq (OpenAI-compatible) — https://console.groq.com
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- App ----------------------------------------------------
DEBUG=false
# "json" for production (structured logs), "text" for dev (colorized).
LOG_FORMAT=json
# Include every origin the browser will use. Add https://localhost for `make up-prod`.
CORS_ORIGINS=["http://localhost:3000","https://localhost"]

# --- Rate Limiting ------------------------------------------
RATE_LIMIT_PER_MINUTE=100

# --- Stripe (OPTIONAL — leave blank to disable /api/payments/*) -
# Get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MODE=test

# --- Postgres (Docker only) ---------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
